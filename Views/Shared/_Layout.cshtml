<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - DigitalStore</title>

    <link rel="icon" type="image/x-icon" href="~/assets-bootstrap/favicon.ico" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>

    <link href="~/css-bootstrap/styles.css" rel="stylesheet" />
</head>

<body>
        <header>
                    @await Component.InvokeAsync("NavBar")
        </header>

        <div class="container-fluid m-0 p-0">
            <main role="main">
                @if (TempData["MensagemSucesso"] != null)
                {
                    <div class="alert alert-dark mx-4" role="alert">
                        <button type="button" class="btn btn-dark btn-sm close-alert" data-bs-dismiss="alert" aria-label="Close"></button>
                        @TempData["MensagemSucesso"]
                    </div>
                }
                @if (TempData["MensagemErro"] != null)
                {
                    <div class="alert alert-dark mx-4" role="alert">
                        <button type="button" class="btn btn-ou btn-sm close-alert" data-bs-dismiss="alert" aria-label="Close"></button>
                        @TempData["MensagemErro"]
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    <footer class="bg-dark text-white py-5">
        <div class="container pb-3">
            <div class="row text-center align-items-center">
                <!-- FRETE GRÁTIS -->
                <div class="col-md-4 d-flex flex-row align-items-center justify-content-center border-end border-white">
                    <i class="bi bi-truck fs-2 text-white me-3"></i>
                    <div>
                        <h6 class="fw-bold mb-0">FRETE GRÁTIS</h6>
                        <p class="mb-0">Em produtos selecionados</p>
                    </div>
                </div>
                <!-- ENTREGA EXPRESSA -->
                <div class="col-md-4 d-flex flex-row align-items-center justify-content-center border-end border-white">
                    <i class="bi bi-lightning-charge fs-2 text-white me-3"></i>
                    <div>
                        <h6 class="fw-bold mb-0">ENTREGA EXPRESSA</h6>
                        <p class="mb-0">A partir de 2 dias úteis</p>
                    </div>
                </div>
                <!-- EM ATÉ 10X SEM JUROS -->
                <div class="col-md-4 d-flex flex-row align-items-center justify-content-center">
                    <i class="bi bi-credit-card fs-2 text-white me-3"></i>
                    <div>
                        <h6 class="fw-bold mb-0">EM ATÉ 10X SEM JUROS</h6>
                        <p class="mb-0">Parcelamento facilitado</p>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="row">
                <!-- Coluna 1 - Sobre a empresa -->
                <div class="col-md-4 mb-3">
                    <h6 class="text-uppercase">Sobre nós</h6>
                    <p class="small">
                        A Digital Store oferece uma ampla variedade de eletrônicos de alta qualidade com entrega rápida e suporte excepcional.
                        Nossa missão é fornecer os melhores produtos com a melhor experiência de compra online.
                    </p>
                </div>

                <!-- Coluna 2 - Links úteis -->
                <div class="col-md-4 mb-3">
                    <h6 class="text-uppercase">Links úteis</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-white text-decoration-none">Política de Privacidade</a></li>
                        <li><a href="#" class="text-white text-decoration-none">Termos de Serviço</a></li>
                        <li><a href="#" class="text-white text-decoration-none">Política de Devoluções</a></li>
                        <li><a href="#" class="text-white text-decoration-none">Ajuda & Suporte</a></li>
                    </ul>
                </div>

                <!-- Coluna 3 - Contato -->
                <div class="col-md-4 mb-3">
                    <h6 class="text-uppercase">Contato</h6>
                    <ul class="list-unstyled">
                        <li><strong>Telefone:</strong> (81) 4002-1234</li>
                        <li><strong>E-mail:</strong> <a href="mailto:suporte@digitalstore.com" class="text-white text-decoration-none">suporte@digitalstore.com</a></li>
                        <li><strong>WhatsApp:</strong> <a href="https://wa.me/5511999998888" target="_blank" class="text-white text-decoration-none">(11) 99999-8888</a></li>
                    </ul>
                </div>
            </div>

            <hr class="my-4" />

            <div class="text-center">
                <p class="small mb-0">&copy; 2024 Digital Store. Todos os direitos reservados.</p>
            </div>
        </div>
    </footer>

    

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://js.stripe.com/v3/"></script>
    <script src="~/js-bootstrap/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.11/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
   
</body>
</html>
