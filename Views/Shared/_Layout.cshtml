<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - DigitalStore</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DigitalStore.styles.css" asp-append-version="true" />
</head>

<body>
    <div class="container-fluid p-0 m-0">
        <header>
                    @await Component.InvokeAsync("Categoria")
        </header>

        <div class="container-fluid m-0 p-0">
            <main role="main">
                @RenderBody()
            </main>
        </div>

        <footer>
            <div class="container-fluid p-0 m-0">

                <div class="footer-row row d-flex justify-content-between mt-5 ms-5">
                    <div class="col d-flex text-center">
                        <i class="bi bi-truck"></i>
                        <p class="pt-3"><b>FRETE GRÁTIS</b><br />Em produtos selecionados</p>
                    </div>
                    <div class="col d-flex text-center">
                        <i class="bi bi-stopwatch"></i>
                        <p class="pt-3"><b>ENTREGA EXPRESSA</b><br />A partir de 2 dias úteis</p>
                    </div>
                    <div class="col d-flex text-center">
                        <i class="bi bi-credit-card"></i>
                        <p class="pt-3"><b>EM ATÉ 10X SEM JUROS</b><br />no cartão de crédito</p>
                    </div>
                </div>


                <div class="footer-info row d-flex align-items-start text-start justify-content-between mt-3 mb-4">
                    <div class="col flex-column ms-5">
                        <h6>Produtos</h6>
                        <a>Smartphones</a>
                        <a>Notebooks</a>
                        <a>Headphones</a>
                        <a>Relógios</a>
                        <a>Acessórios</a>
                    </div>
                    <div class="col flex-column">
                        <h6>Suporte</h6>
                        <a>Suporte de Produtos</a>
                        <a>Agendar Reparo</a>
                        <a>Acompanhar Reparo</a>
                        <a>Informações de Garantia</a>
                    </div>
                    <div class="col flex-column">
                        <h6>DigitalStore Empresas</h6>
                        <a>Informações da empresa</a>
                        <a>Área de negócios</a>
                        <a>Eventos</a>
                        <a>Blog</a>
                    </div>
                    <div class="col flex-column">
                        <h6>Ajuda</h6>
                        <a>Trocas e Devoluções</a>
                        <a>Minha Conta</a>
                        <a>Meus Pedidos</a>
                        <a>Cancelamentos</a>
                        <a>Entregas</a>
                        <a>Acessibilidade</a>
                    </div>
                    <div class="col flex-column">
                        <h6>Central de Relacionamentos</h6>
                        <a>Tire suas dúvidas</a>
                        <div class="mt-5 pt-5 text-center">
                            <a><i class="bi bi-facebook me-3"></i></a>
                            <a><i class="bi bi-instagram me-3"></i></a>
                            <a><i class="bi bi-twitter me-3"></i></a>
                            <a><i class="bi bi-youtube me-3"></i></a>
                        </div>
                    </div>

                </div>

                <div class="container-fluid ps-4 pb-2 text-center">
                    &copy; DigitalStore. Todos os direitos reservados.
                </div>

            </div>
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.11/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
   
</body>
</html>
