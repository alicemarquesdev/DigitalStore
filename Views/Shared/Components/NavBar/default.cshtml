@using DigitalStore.Enum
@model NavBarViewModel


<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container px-3">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <h4 class="m-0 py-1">@Model.NomeSite</h4>
        </a>
       

        <div class="" id="navbarSupportedContent">
            @if (!Model.UsuarioLogado)
            {
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Login" asp-action="Login">
                            Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Suporte">
                            Suporte
                        </a>
                    </li>
                </ul>
            }
            else
            {
                <ul class="navbar-nav align-items-center ms-auto">

                    @if (Model.PerfilUsuarioCliente)
                    {
                        <li class="nav-item me-4 position-relative">
                            <a class="btn btn-outline-light nav-link p-0" asp-controller="Favorito" asp-action="Favoritos" asp-route-id="@Model.UsuarioLogadoId" style="color: inherit; background-color: transparent; border-color: inherit;">
                                <i class="bi-heart-fill me-1 text-light fs-5"></i>
                                <span class="badge bg-danger text-light position-absolute top-0 start-100 translate-middle rounded-pill" style="width: 1.1rem; height: 1.1rem; font-size: 0.65rem;">
                                    @Model.FavoritosQuantidadeDeProdutos
                                </span>
                            </a>
                        </li>

                        <li class="nav-item position-relative me-3">
                            <a class="btn btn-outline-light nav-link p-0" role="button" asp-controller="Carrinho" asp-action="Carrinho" asp-route-id="@Model.UsuarioLogadoId" style="color: inherit; background-color: transparent; border-color: inherit;">
                                <i class="bi-cart-fill me-1 text-light fs-5"></i>
                                <span class="badge bg-danger text-light position-absolute top-0 start-100 translate-middle rounded-pill" style="width: 1.1rem; height: 1.1rem; font-size: 0.65rem;">
                                    @Model.CarrinhoQuantidadeDeProdutos
                                </span>
                            </a>
                        </li>

                    }
                    else
                    {

                        <li class="nav-item">
                            <a role="button" class="nav-link" asp-controller="Produto" asp-action="GerenciamentoProdutos">Gerenciamento de Produtos</a>
                        </li>
                        <li class="nav-item">
                            <a role="button" class="nav-link" asp-controller="Site" asp-action="Personalizacao">Personalização</a>
                        </li>
                    }

                    <li class="nav-item dropdown ms-2">
                        <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Minha Conta</a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                            @if (Model.PerfilUsuarioCliente)
                            {
                            <li><a class="dropdown-item" asp-controller="Pedido" asp-action="MeusPedidos" asp-route-id="@Model.UsuarioLogadoId"><i class="bi bi-bag-fill fs-5 me-1"></i>  Meus Pedidos</a></li>
                            }
                            <li><a class="dropdown-item" asp-controller="Usuario" asp-action="MinhaConta" asp-route-id="@Model.UsuarioLogadoId"><i class="bi bi-person-fill fs-5 me-1"></i>  Minha Conta</a></li>

                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Suporte"> Suporte</a></li>
                            <li><a class="dropdown-item" asp-controller="Login" asp-action="Sair"> Sair</a></li>
                        </ul>
                    </li>
                </ul>

            }

        </div>

    </div>
</nav>
<nav class="navbar navbar-expand navbar-light bg-light p-0 m-0 shadow-sm">
    <div class="container-fluid">
        <!-- Centralização das categorias -->
        <div class="d-flex justify-content-center flex-grow-1">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        INÍCIO
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" id="dropdownCategorias" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        TODAS AS CATEGORIAS
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="dropdownCategorias">
                        <li>
                            <a class="dropdown-item" asp-controller="Home" asp-action="TodosOsProdutos">
                                Todos os produtos
                            </a>
                        </li>
                        @if(Model.Categorias != null && Model.Categorias.Any())
                        {
                            foreach (var categoria in Model.Categorias)
                            {
                                <li>

                                    <a class="dropdown-item" asp-controller="Home" asp-action="Categoria" asp-route-categoria="@categoria">
                                        @categoria
                                    </a>
                                </li>
                            }
                        }

                    </ul>
                </li>
                @if (Model.Categorias != null && Model.Categorias.Any())
                {
                    foreach (var categoria in Model.Categorias.Take(5))
                    {
                        <li class="nav-item">   
                            <a class="nav-link" asp-controller="Home" asp-action="Categoria" asp-route-categoria="@categoria">
                                @categoria.ToUpper()
                            </a>
                        </li>
                    }
                }
                

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="UltimasNovidades">
                        ÚLTIMAS NOVIDADES
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>
