    @using DigitalStore.Enum
@model List<ProdutoModel>


<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container px-4 px-lg-4">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">@ViewBag.SiteDados</a>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">


            @if (ViewBag.Sessao == null)
            {
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 me-lg-1">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Login" asp-action="Index">
                            Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Suporte">
                            Suporte
                        </a>
                    </li>
                </ul>

            }
            else
            {
                <ul class="navbar-nav align-items-center ms-auto mb-2 mb-lg-0 me-lg-1">

                    @if (ViewBag.UsuarioPerfil == PerfilEnum.Cliente)
                    {

                        <li class="nav-item me-2">
                            <a class="btn btn-outline-light nav-link" asp-controller="Favorito" asp-action="Favoritos" asp-route-id="@ViewBag.UsuarioId" style="color: inherit; background-color: transparent; border-color: inherit;">
                                <i class="bi-heart-fill me-1 text-light"></i>
                                <span class="badge bg-light text-dark ms-1 rounded-pill">@ViewBag.FavoritosQuantidadeDeProdutos</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light nav-link" role="button" asp-controller="Carrinho" asp-action="Carrinho" asp-route-id="@ViewBag.UsuarioId"
                               style="color: inherit; background-color: transparent; border-color: inherit;">
                                <i class="bi-cart-fill me-1 text-light"></i>
                                <span class="badge bg-light text-dark ms-1 rounded-pill">@ViewBag.CarrinhoQuantidadeDeProdutos</span>
                            </a>
                        </li>

                    }
                    else
                    {

                        <li class="nav-item">
                            <a role="button" class="nav-link" asp-controller="Produto" asp-action="GerenciamentoProdutos">Gerenciamento de Produtos</a>
                        </li>
                        <li class="nav-item">
                            <a role="button" class="nav-link" asp-controller="Site" asp-action="Personalizacao">Personalização</a>
                        </li>
                    }

                    <li class="nav-item dropdown ms-2">
                        <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Minha Conta</a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" asp-controller="Pedido" asp-action="MeusPedidos" asp-route-Id="@ViewBag.UsuarioId"><i class="bi bi-bag"></i> Meus Pedidos</a></li>
                            <li><a class="dropdown-item" asp-controller="Usuario" asp-action="MinhaConta" asp-route-Id="@ViewBag.UsuarioId"><i class="bi bi-person"></i> Minha Conta</a></li>

                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Suporte"><i class="bi bi-question-circle"></i> Suporte</a></li>
                            <li><a class="dropdown-item" asp-controller="Login" asp-action="Sair"><i class="bi bi-box-arrow-right"></i> Sair</a></li>
                        </ul>
                    </li>
                </ul>

            }

        </div>

    </div>
</nav>
<nav class="navbar navbar-expand navbar-light bg-light p-0 m-0 shadow-lg">
    <div class="container-fluid">
        <!-- Centralização das categorias -->
        <div class="d-flex justify-content-center flex-grow-1">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        INÍCIO
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" id="dropdownCategorias" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        TODAS AS CATEGORIAS
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="dropdownCategorias">
                        <li>
                            <a class="dropdown-item" asp-controller="Home" asp-action="TodosOsProdutos" asp-route-id="@ViewBag.UsuarioId">
                                Todos os produtos
                            </a>
                        </li>
                        @foreach (var categoria in Model)
                        {
                            <li>

                                <a class="dropdown-item" asp-controller="Home" asp-action="Categoria" asp-route-categoria="@categoria.Categoria">
                                    @categoria.Categoria
                                </a>
                            </li>
                        }
                    </ul>
                </li>

                @foreach (var categoria in Model.Take(5))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Categoria" asp-route-categoria="@categoria.Categoria" asp-route-id="@ViewBag.UsuarioId">
                            @categoria.Categoria.ToUpper()
                        </a>
                    </li>
                }

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="UltimasNovidades" asp-route-id="@ViewBag.UsuarioId">
                        ÚLTIMAS NOVIDADES
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>
