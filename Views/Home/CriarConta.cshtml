@using DigitalStore.Enum
@model UsuarioModel

@{
    ViewData["Title"] = "Criar Conta";
}

<div class="container p-2">
    <h1 class="mb-4 mt-5">Crie sua conta</h1>
</div>

<div class="container p-2  mb-5">
    <form asp-controller="Usuario" asp-action="AddUsuario" method="post">
        <div>
            <label for="nome">Nome</label>
            <input asp-for="Nome" class="form-control" type="text" max="100" />
            <span class="text-danger">

            @Html.ValidationMessageFor(x => x.Nome)
            </span>
        </div>
        <div class=" mt-3">
            <label for="email">Email</label>
            <input asp-for="Email" class="form-control" type="email" max="50" />
            <span class="text-danger">

            @Html.ValidationMessageFor(x => x.Email)
            </span>
        </div>
        <div class=" mt-3">
            <label for="NomeSite">Digite o nome da sua marca/site</label>
            <input asp-for="NomeSite" class="form-control" type="text" max="25" />
            <span class="text-danger">

            @Html.ValidationMessageFor(x => x.NomeSite)
            </span>
        </div>
        <div class=" mt-3">
            <label for="senha">Senha</label>
            <input asp-for="Senha" class="form-control" type="password" min="8" max="12" />
            <span class="text-danger">

            @Html.ValidationMessageFor(x => x.Senha)
            </span>
        </div>

        <div class=" mt-3">
            <label for="Perfil">Perfil</label>
            <select asp-for="Perfil" class="form-select">
                <option value="">Selecione</option>
                <option value="@PerfilEnum.Admin">Administrador</option>
                <option value="@PerfilEnum.Cliente">Cliente</option>
            </select>
            <span class="text-danger">
            @Html.ValidationMessageFor(x => x.Perfil)
            </span>
        </div>

            <button type="submit" class="btn btn-dark mb-2 mt-5 d-block w-100">Criar Conta</button>
            <a class="btn btn-dark d-block" role="button">Voltar</a>

    </form>

</div>