@model LoginModel

@{
    ViewData["Title"] = "Login";
}

@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger" role="alert">
        <button type="button" class="btn btn-danger btn-sm close-alert" data-bs-dismiss="alert" aria-label="Close">X</button>
        @TempData["MensagemErro"]
    </div>
}



<div class="container p-2">
    <h1 class="mb-4 mt-5">Login</h1>
</div>

<div class="container p-2 mb-5">
    <form asp-controller="Home" asp-action="Entrar" method="post">
        <div>
            <label for="email">Login</label>
            <input class="form-control" type="text" asp-for="Email" placeholder="*Digite o seu Email" />
            @Html.ValidationMessageFor(x => x.Email)
        </div>
        <div class=" mt-3">
            <label for="senha">Senha</label>
            <input class="form-control" type="password" asp-for="Senha" placeholder="*Digite sua senha" />
            @Html.ValidationMessageFor(x => x.Senha)
         </div>

          <button type="submit" class="btn btn-dark mb-2 mt-4 d-block w-100">Entrar</button>
           <a class="btn btn-dark d-block" role="button">Voltar</a>

    </form>

</div>