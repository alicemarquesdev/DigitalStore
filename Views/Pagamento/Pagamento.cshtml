@model PagamentoViewModel

@{
    ViewData["Title"] = "Pagamento";
}

<div class="container my-lg-5 pb-md-5">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a class="text-decoration-none text-dark" asp-controller="Carrinho" asp-action="Carrinho" asp-route-id="@Model.Endereco.UsuarioId">
                <i class="bi bi-arrow-left"></i>Carrinho
            </a>
        </li>

        <li class="breadcrumb-item active" aria-current="page">Pagamento</li>
    </ol>

    <div class="row mb-4">
        <!-- Left Section: Pagamento -->
        <div class="col-md-7">
            <h4 class="mb-4">Pagamento</h4>

            <!-- Cartão de Crédito -->
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3"><i class="bi bi-credit-card"></i> Cartão de Crédito</h5>
                    <form id="payment-form" method="post">

                        <!-- Input de Nome no Cartão -->
                        <div class="form-group mb-3">
                            <label for="card-name">Nome no Cartão</label>
                            <input type="text" id="card-name" class="form-control" placeholder="Nome no Cartão" style="border-radius: 5px; padding: 10px;" required>
                        </div>

                        <!-- Input de Número do Cartão -->
                        <div class="form-group mb-3">
                            <label for="card-number">Número do Cartão</label>
                            <div id="card-number" class="form-control" style="border-radius: 5px; padding: 10px;" required></div>
                        </div>

                        <!-- Linha de inputs para Expiração e CVC -->
                        <div class="row mb-4">
                            <!-- Expiração -->
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="card-expiry">Mês e Ano de Expiração</label>
                                    <div id="card-expiry" class="form-control" style="border-radius: 5px; padding: 10px;" required></div>
                                </div>
                            </div>

                            <!-- CVC com ícone -->
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="card-cvc">CVC</label>
                                    <div id="card-cvc" class="form-control" style="border-radius: 5px; padding: 10px;" required></div>
                                </div>
                            </div>
                        </div>

                        <!-- Mensagem de erro -->
                        <div id="card-errors" role="alert" class="text-danger"></div>

                        <!-- Botão de pagamento -->
                        <div class="container d-flex justify-content-end">
                            <button type="submit" class="btn btn-dark w-100">Pagar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Section: Resumo do Pedido -->
        <div class="col-md-5">
            <h5 class="mb-4 mt-1">Endereço de Entrega</h5>
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    @if (Model.Endereco != null)
                    {
                        <p><strong>@Model.Endereco.EnderecoCompleto</strong></p>
                    }
                </div>
            </div>

            <h4 class="mb-3">Resumo do Pedido</h4>
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <p class="mb-2">Subtotal</p>
                        <p class="mb-2 fw-bold">R$ @Model.CarrinhoTotal</p>
                    </div>
                    <div class="d-flex justify-content-between">
                        <p class="mb-2">Valor do Frete:</p>
                        <p class="mb-2 fw-bold">R$ @Model.Frete</p>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <h6 class="fw-bold">Total</h6>
                        <h6 class="fw-bold">R$ @(Model.CarrinhoTotal + Model.Frete)</h6>
                    </div>
                    <a class="btn btn-dark w-100 mt-3" asp-controller="Pagamento" asp-action="Pagamento">Finalizar Compra</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://js.stripe.com/v3/"></script>
<script>
    var stripe = Stripe('pk_test_51Qcwp7JdK4WCtqrXUbyXtGNl59DXGXKG7NEQeZte1c8tM1xam9IXgYPmE5DlnzHRWHpjMbL7uIyzfvsGuEhnGPbb00WvjgYFSw'); // Sua chave pública do Stripe
    var elements = stripe.elements();

    var style = {
        base: {
            color: '#32325d',
            fontFamily: '"Helvetica Neue", Helvetica, sans-serif',
            fontSize: '16px',
            '::placeholder': {
                color: '#aab7c4'
            }
        },
        invalid: {
            color: '#fa755a',
            iconColor: '#fa755a'
        }
    };

    // Criando os componentes para o número do cartão, expiração e CVC
    var cardNumber = elements.create('cardNumber', { style: style });
    var cardExpiry = elements.create('cardExpiry', { style: style });
    var cardCvc = elements.create('cardCvc', { style: style });

    // Montando os campos na página
    cardNumber.mount('#card-number');
    cardExpiry.mount('#card-expiry');
    cardCvc.mount('#card-cvc');

    var form = document.getElementById('payment-form');
    form.addEventListener('submit', function (event) {
        event.preventDefault();

        stripe.createToken(cardNumber).then(function (result) {
            console.log(result); // Verifica se há erro no token

            if (result.error) {
                // Exibe o erro para o usuário
                var errorElement = document.getElementById('card-errors');
                errorElement.textContent = result.error.message;
            } else {
                // Envia o token para o backend
                var stripeModel = {
                     UsuarioId: parseInt('@Model?.Endereco?.UsuarioId', 10),  // Convertendo para inteiro
    EnderecoId: parseInt('@Model?.Endereco?.EnderecoId', 10),  // Convertendo para inteiro
                    Token: result.token.id, // O token gerado
    Valor: parseFloat('@Model?.Valor').toFixed(2), // Convertendo para float
                    // A moeda é sempre BRL, e a descrição é fixa
                    Moeda: "brl", // Moeda (real, no caso)
                    Descricao: "Compra na DigitalStore" // Descrição fixa
                };
                        console.log(stripeModel); // Verificando o objeto antes de enviar


                // Envia a requisição para o backend
                fetch('/Pagamento/ProcessarPagamento', {
                    method: 'POST',
                    body: JSON.stringify(stripeModel),
                    headers: {
                        'Content-Type': 'application/json'
                    }
                }).then(function (response) {
                    return response.json();
                }).then(function (data) {
                    if (data.success) {
                        window.location.href = '/Pagamento/PagamentoSucesso'; // Redireciona para a página de sucesso
                    } else {
                        alert("Erro no pagamento: " + data.message);
                    }
                }).catch(function (error) {
                    alert("Erro na requisição: " + error.message);
                });
            }
        });
    });
</script>
