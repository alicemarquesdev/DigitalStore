@{
    ViewData["Title"] = "Minha Conta";
}

<div class="container my-5">
    <div class="row">
        <!-- Sidebar Left -->
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li><a asp-controller="Pedido" asp-action="MeusPedidos" asp-route-Id="@ViewBag.UsuarioId" class="text-decoration-none text-dark fw-bold text-start">Meus Pedidos</a></li>
                        <hr class="w-100 mx-auto border-2 border-secondary">
                        
                        <li><a asp-controller="Usuario" asp-action="MinhaConta" asp-route-Id="@ViewBag.UsuarioId" class="text-decoration-none text-dark fw-bold text-start">Meus Dados</a></li>
                        <hr class="w-100 mx-auto border-2 border-secondary">

                        
                        <li><a asp-controller="Usuario" asp-action="AlterarSenha" asp-route-Id="@ViewBag.UsuarioId" class="text-decoration-none text-dark fw-bold text-start">Alterar Senha</a></li>
                        <hr class="w-100 mx-auto border-2 border-secondary">

                        <li>
                            <a asp-controller="Usuario" asp-action="ApagarUsuario" asp-route-Id="@ViewBag.UsuarioId" class="text-decoration-none text-dark fw-bold text-start">
                                Apagar Conta
                            </a>
                        </li>

                        <hr class="w-100 mx-auto border-2 border-secondary">

                        <li>
                            <a class="text-decoration-none text-dark fw-bold text-start" asp-controller="Login" asp-action="Sair">
                                <i class="bi bi-box-arrow-right"></i> Sair
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Content: User Data -->
        <div class="col-md-9">
            <h2 class="text-center mb-5">Minha Conta</h2>

            <!-- Dados do Usuário -->
            <div class="card shadow-sm mb-4" id="meusDados">
                <div class="card-header">
                    <h5 class="mb-0">Seus Dados</h5>
                </div>
                <div class="card-body">
                    <form method="post" action="#" id="formDadosUsuario">
                            <div class="col-md-6 mb-3">
                                <label for="NomeUsuario" class="form-label">Nome</label>
                                <input type="text" class="form-control" id="NomeUsuario" value="João Silva" readonly>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="EmailUsuario" class="form-label">E-mail</label>
                                <input type="email" class="form-control w-100" id="EmailUsuario" value="joao.silva@email.com" readonly>
                            </div>

                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-dark d-block w-100">Salvar Informações</button>
                        </div>
                    </form>
                </div>
            </div>

           

        </div>
    </div>
</div>
