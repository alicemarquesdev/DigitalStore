@model UsuarioModel

@{
    ViewData["Title"] = "Apagar Conta";
}


<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header"><h3 class="text-center font-weight-light my-4">Apagar Conta</h3></div>

                <div class="card-body">
                    <p>@ViewBag.UsuarioNome, deseja realmente apagar sua conta?</p>

                    <form asp-controller="Usuario" asp-action="ApagarUsuarioConfirmacao" method="post">
                        <div class=" mt-4 mb-0">
                            <button type="submit" class="btn btn-dark d-block w-100 mb-1">Apagar Conta</button>
                            <a class="btn btn-dark d-block w-100" asp-controller="Usuario" asp-action="MinhaConta">Voltar</a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>