@model SiteModel

@{
    ViewData["Title"] = "Personalização";
}

<div class="container my-5">
    <h2 class="text-center mb-4">Personalização do Site</h2>

    <form method="post" enctype="multipart/form-data" asp-action="AtualizarSite" asp-controller="Site">
        <!-- Nome do Site -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5>Nome do Site</h5>
            </div>
            <div class="card-body">
                <label asp-for="NomeSite" class="form-label">Digite o nome do site</label>
                <input asp-for="NomeSite" class="form-control" placeholder="Nome do site" required>
                <span asp-validation-for="NomeSite" class="text-danger"></span>
            </div>
        </div>

        <!-- Banner 1 -->
        <div class="mb-3">
            <label for="ImagemFile1" class="form-label">Banner 1</label>
            <input class="form-control" id="ImagemFile1" type="file" name="imagem1" />
        </div>
       
        <div class="text-center">
            <label for="ImagemFile1">
                <img id="img" style="max-width:300px; max-height:300px" />
            </label>
        </div>

        <!-- Banner 2 -->
        <div class="mb-3">
            <label for="ImagemFile2" class="form-label">Banner 2</label>
            <input class="form-control" id="ImagemFile2" type="file" name="imagem2" />
        </div>
        <div class="text-center">
            <label for="ImagemFile2">
                <img id="img" style="max-width:300px; max-height:300px" />
            </label>
        </div>

        <!-- Banner 3 -->
        <div class="mb-3">
            <label for="ImagemFile3" class="form-label">Banner 3</label>
            <input class="form-control" id="ImagemFile3" type="file" name="imagem3" />
        </div>
        <div class="text-center">
            <label for="ImagemFile3">
                <img id="img" style="max-width:300px; max-height:300px" />
            </label>
        </div>

        <!-- Banner 4 -->
        <div class="mb-3">
            <label for="ImagemFile4" class="form-label">Banner 4</label>
            <input class="form-control" id="ImagemFile4" type="file" name="imagem4" />
        </div>
        <div class="text-center">
            <label for="ImagemFile4">
                <img id="img" style="max-width:300px; max-height:300px" />
            </label>
        </div>

        <!-- Frase da Home Page -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5>Frase da Home Page</h5>
            </div>
            <div class="card-body">
                <label asp-for="Frase" class="form-label">Digite a frase para a página inicial</label>
                <textarea asp-for="Frase" rows="3" class="form-control" placeholder="Frase que aparece na home"></textarea>
                <span asp-validation-for="Frase" class="text-danger"></span>
            </div>
        </div>

        <!-- Botão de Salvar -->
        <div class="d-flex justify-content-end">
            <button type="submit" class="btn btn-dark">
                <i class="bi bi-check-circle"></i> Salvar Personalização
            </button>
        </div>
    </form>
</div>
