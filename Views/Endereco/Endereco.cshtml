@model List<EnderecoModel>

@{
    ViewData["Title"] = "Endereço de Envio";
}

<div class="container my-lg-5 pb-md-5">
    <!-- Breadcrumb -->
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a class="text-decoration-none text-dark" asp-controller="Carrinho" asp-action="Carrinho" asp-route-id="@ViewBag.UsuarioId">
                <i class="bi bi-arrow-left"></i> Retornar ao Carrinho</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">
            Endereço de Envio
        </li>
    </ol>

    <!-- Título -->
    <h4 class="mb-4">Endereço de Envio</h4>

    <!-- Card Principal -->
    <div class="card shadow-sm">
        <div class="card-body">
            <!-- Conteúdo Condicional -->
            @if (Model != null && Model.Any())
            {
                <h5 class="card-title">Selecione um Endereço</h5>
                @foreach (var endereco in Model)
                {
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="EnderecoId" value="@endereco.EnderecoId" id="@endereco.EnderecoId" />
                        <label class="form-check-label" for="@endereco.EnderecoId">
                            <strong>@endereco.Rua</strong>, @endereco.Bairro, @endereco.Cidade - @endereco.Estado, CEP: @endereco.CEP
                        </label>
                        <div class="mt-2 d-flex gap-2">
                            <a asp-controller="Endereco" asp-action="AtualizarEndereco" asp-route-id="@endereco.EnderecoId" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <form asp-controller="Endereco" asp-action="RemoverEndereco" method="post">
                                <input type="hidden" name="id" value="@endereco.EnderecoId" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash3"></i> Remover
                                </button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">Você ainda não possui endereços cadastrados.</p>
            }

            <!-- Botão Adicionar Novo Endereço -->
            <div class="text-end mt-4">
                <a asp-controller="Endereco" asp-action="AddEndereco" asp-route-Id="@ViewBag.UsuarioId" class="btn btn-outline-dark">
                    <i class="bi bi-plus-circle"></i> Adicionar Novo Endereço
                </a>
            </div>
        </div>
    </div>

    <!-- Botão Prosseguir -->
    <div class="text-center mt-4">
        <a asp-controller="Pagamento" asp-action="Pagamento" asp-route-Id="@ViewBag.UsuarioId" class="btn btn-primary w-50">
            Prosseguir para Pagamento <i class="bi bi-arrow-right"></i>
        </a>
    </div>
</div>
