@model EnderecoModel

@{
    ViewData["Title"] = "Atualizar Endereço";
}

<div class="container mb-5">
    <div class="d-flex justify-content-start mt-3">
        <a class="text-decoration-none text-dark" asp-controller="PerfilAdmin" asp-action="GerenciamentoEnderecos">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header">
                    <h3 class="text-center font-weight-light my-4">Atualizar Endereço</h3>
                </div>
                <div class="card-body">
                    <form asp-controller="Endereco" asp-action="AtualizarEndereco" method="post">
                        <!-- Campo oculto para o ID do endereço -->
                        <input type="hidden" asp-for="EnderecoId" />

                        <div class="form-floating mb-3">
                            <input class="form-control" type="text" asp-for="Rua" id="Rua" />
                            <label for="Rua">Rua</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.Rua)</span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" type="text" asp-for="Bairro" id="Bairro" />
                            <label for="Bairro">Bairro</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.Bairro)</span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" type="text" asp-for="Cidade" id="Cidade" />
                            <label for="Cidade">Cidade</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.Cidade)</span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" type="text" asp-for="Estado" id="Estado" />
                            <label for="Estado">Estado</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.Estado)</span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" type="text" asp-for="CEP" id="CEP" />
                            <label for="CEP">CEP</label>
                            <span class="text-danger">@Html.ValidationMessageFor(x => x.CEP)</span>
                        </div>

                        <div class="mt-4 mb-0">
                            <button type="submit" class="btn btn-dark d-block w-100 mb-1">Atualizar Endereço</button>
                            <a class="btn btn-dark d-block w-100" asp-controller="PerfilAdmin" asp-action="GerenciamentoEnderecos">Voltar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
