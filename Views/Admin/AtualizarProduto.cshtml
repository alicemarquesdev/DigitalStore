@model ProdutoModel

@{
    ViewData["Title"] = "Atualizar Produto";
}

@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger" role="alert">
        <button type="button" class="btn btn-danger btn-sm close-alert" data-bs-dismiss="alert" aria-label="Close">X</button>
        @TempData["MensagemErro"]
    </div>
}



<div class="container p-2">
    <h1 class="mb-4 mt-5">Atualizar Produto</h1>
</div>

<div class="container mb-lg-5 ">
    <form asp-controller="Admin" asp-action="AddProduto" method="post">

        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label for="produto">Produto</label>
            <input class="form-control" type="text" asp-for="NomeProduto" placeholder="Digite o nome do produto." />
            @Html.ValidationMessageFor(x => x.NomeProduto)
        </div>
        <div class="form-group mb-3">
            <label for="preco">Preço</label>
            <input class="form-control" type="number" asp-for="Preco" placeholder="Digite o preço do produto" min="0" step="0.01" />
            @Html.ValidationMessageFor(x => x.Preco)
        </div>
        <div class="form-group mb-3">
            <label for="categoria">Categoria</label>
            <input class="form-control" type="text" asp-for="Categoria" placeholder="Digite a categoria do produto." />
            @Html.ValidationMessageFor(x => x.Categoria)
        </div>
        <div class="form-group mb-3">
            <label for="ImagemUrl">Insira uma imagem do produto:</label>
            <input class="form-control" type="file" asp-for="Categoria" accept=".jpg, .jpeg, .png" placeholder="Insira uma imagem do produto." />
            @Html.ValidationMessageFor(x => x.ImagemUrl)
        </div>
        <button type="submit" class="btn btn-dark mb-2 mt-5 d-block w-100">Atualizar Produto</button>
        <a class="btn btn-dark d-block" asp-controller="Admin" asp-action="Index">Voltar</a>

    </form>

</div>