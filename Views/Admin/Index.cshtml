@model List<ProdutoModel>

@{
    ViewData["Title"] = "Gerenciamento de Produtos";
}

<div class="container">
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-success btn-sm close-alert" data-bs-dismiss="alert" aria-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>
    }
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" data-bs-dismiss="alert" aria-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>
    }
</div>


<div class="container p-2">
    <h1 class="mb-4 mt-5">Gerenciamento de Produtos</h1>
</div>


<div class="container card mb-5">
    <div class="card-header d-flex justify-content-between align-items-center fw-bold">
        <div>
            Lista Geral de Produtos
        </div>
        <div class="ms-auto">
            <a class="btn btn-dark " asp-controller="Admin" asp-action="AddProduto">Adicionar Produto</a>
        </div>
    </div>

    <div class="card-body">
        <table id="table-produtos" class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th scope="col">Produto</th>
                    <th scope="col">Categoria</th>
                    <th scope="col">Descrição</th>
                    <th scope="col">Quantidade em Estoque</th>
                    <th scope="col">Preço</th>
                    <th scope="col">Atualizar</th>
                    <th scope="col">Remover</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var produto in Model)
                    {
                        <tr>
                            <th scope="row">@produto.NomeProduto</th>
                            <td>@produto.Categoria</td>
                            <td>@produto.Descricao</td>
                            <td>@produto.QuantidadeEstoque</td>
                            <td>R$@produto.Preco</td>
                            <td>
                                <a class="btn btn-secondary d-block" asp-controller="Admin" asp-action="AtualizarProduto" asp-route-id="@produto.ProdutoId">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </a>
                            </td>
                            <td>
                                <form asp-controller="Admin" asp-action="RemoverProduto" method="post">
                                            <input type="hidden" name="id" value="@produto.ProdutoId" />
                                    <button type="submit" class="btn btn-danger d-block w-100"><i class="bi bi-trash3"></i></button>
                                </form>

                            </td>

                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>